#!/bin/sh
# EKP pre-commit hook — backend ruff lint check on staged Python files.
# 啟用一次: git config core.hooksPath scripts/hooks
# 緊急跳過: git commit --no-verify
#
# 註: 暫只跑 ruff check (lint),未納入 ruff format --check —
#     實測現有 codebase format 未統一(如 models.py),啟用 format check
#     前需先全庫跑一次 'ruff format',否則改任何檔都會被攔。詳見 README.md。
set -e

STAGED_PY=$(git diff --cached --name-only --diff-filter=ACM | grep -E '^backend/.*\.py$' || true)
[ -z "$STAGED_PY" ] && exit 0

RUFF="backend/.venv/Scripts/ruff.exe"
[ -f "$RUFF" ] || RUFF="ruff"

echo "[pre-commit] ruff check (lint) on staged backend files..."
"$RUFF" check $STAGED_PY || { echo "[pre-commit] FAILED — 修好 lint 先 commit (急可 --no-verify)"; exit 1; }

echo "[pre-commit] backend lint OK"