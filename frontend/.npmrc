# Local Windows + OneDrive workaround (W11 D2 cont 2026-06-10)
# pnpm default symlink-based .pnpm/ store creates deep paths (~250+ chars)
# that fail Node.js runtime reads through OneDrive Files-On-Demand reparse
# points (errno -4094 UNKNOWN). Hoisted+shamefully-hoist forces flat layout
# (npm-style) eliminating the .pnpm/ chain entirely.
# Tradeoff: ~10x more disk vs eliminating symlink-chain runtime failures.
node-linker=hoisted
shamefully-hoist=true
