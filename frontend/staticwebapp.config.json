{
  "$schema": "https://json.schemastore.org/staticwebapp.config.json",
  "_comment": "EKP frontend SWA config (W8 D3 F3.4). Next.js App Router needs SPA fallback for client-side routes; auth response status mapping bridges 401/403 from backend to frontend ErrorBoundary (F4.2). MIME hints needed for some Next.js build output static files.",

  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [
      "/api/*",
      "/_next/*",
      "/static/*",
      "/*.{ico,png,jpg,jpeg,gif,svg,css,js,json,webp,woff,woff2}"
    ]
  },

  "responseOverrides": {
    "401": {
      "redirect": "/admin",
      "statusCode": 302
    },
    "403": {
      "rewrite": "/admin/error.html",
      "statusCode": 403
    },
    "404": {
      "rewrite": "/index.html",
      "statusCode": 200
    }
  },

  "globalHeaders": {
    "X-Frame-Options": "DENY",
    "X-Content-Type-Options": "nosniff",
    "Referrer-Policy": "strict-origin-when-cross-origin",
    "Permissions-Policy": "geolocation=(), microphone=(), camera=()",
    "Strict-Transport-Security": "max-age=31536000; includeSubDomains"
  },

  "mimeTypes": {
    ".json": "application/json",
    ".woff": "application/font-woff",
    ".woff2": "application/font-woff2"
  },

  "platform": {
    "apiRuntime": "node:20"
  }
}
