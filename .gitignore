# ============================================================================
# EKP — Git Ignore
# ============================================================================
#
# Reference:
#   - setup.md §4.1(reference repo gitignore)
#   - REFERENCE_USAGE.md §1(read-only reference policy)
#   - .env.example(secrets policy)
#
# Maintenance:
#   新增 build / cache 路徑時 update 呢個 file,唔好 individual `.gitignore` 散喺 sub-folder。
# ============================================================================


# ----------------------------------------------------------------------------
# Secrets — NEVER commit
# ----------------------------------------------------------------------------
.env
.env.*
!.env.example
*.pem
*.key
*.pfx
secrets/
.secrets/

# Env-resource detail dump folder (plaintext credentials staging area before .env wiring)
# 詳見 docs/setup.md §5 — credentials 應該 only live in .env (gitignored)
docs/11-env-resources-detail/

# Source sample documents (Drive Project user manuals — per Q2)
# Large binaries (~36MB total), tracked separately by stakeholder
# Path referenced in code/eval; folder existence + presence verified at runtime
docs/06-reference/01-sample-doc/


# ----------------------------------------------------------------------------
# Reference Repositories(read-only,clone locally)
# ----------------------------------------------------------------------------
# 詳見 references/REFERENCE_USAGE.md
references/dify/
references/*/
!references/REFERENCE_USAGE.md
!references/.gitkeep
!references/design-mockups/


# ----------------------------------------------------------------------------
# Python / Backend(uv + pytest + ruff)
# ----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# uv / virtualenv
.venv/
venv/
env/
.python-version

# Build / Distribution
build/
dist/
*.egg-info/
*.egg
wheels/
.eggs/

# Test / Coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
coverage.xml
*.cover

# Linter / Formatter / Type checker cache
.ruff_cache/
.mypy_cache/
.pyre/
.dmypy.json


# ----------------------------------------------------------------------------
# Node / Frontend(Next.js 14 + pnpm + shadcn/ui)
# ----------------------------------------------------------------------------
node_modules/
.pnpm-store/

# Next.js
.next/
out/
.vercel/

# Build artifacts
build/
*.tsbuildinfo
next-env.d.ts

# pnpm / npm logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-debug.log*

# Playwright MCP transient capture metadata (consoles + page snapshots);
# screenshots saved under docs/02-architecture/responsive-audit-W7/ are
# committed evidence — do NOT ignore those.
.playwright-mcp/

# Playwright E2E test artifacts (W15 D4 F4 baseline harness — frontend/tests/e2e/);
# baseline screenshots under tests/e2e/*.spec.ts-snapshots/ ARE committed
# (visual regression contract per W15 plan §F4.4) — do NOT ignore those.
frontend/test-results/
frontend/playwright-report/
frontend/playwright/.cache/


# ----------------------------------------------------------------------------
# Docker / Local Dev Stack
# ----------------------------------------------------------------------------
# Azurite emulator local data(infrastructure/docker-compose.yml volumes)
infrastructure/azurite-data/

# Postgres / Langfuse local data(若用 bind mount instead of named volume)
infrastructure/postgres-data/
infrastructure/langfuse-uploads/

# Docker compose override(local dev experiments)
docker-compose.override.yml
docker-compose.*.local.yml


# ----------------------------------------------------------------------------
# Eval / Reports / Generated Artifacts
# ----------------------------------------------------------------------------
# Per-run eval reports(eval-methodology.md §6.1)
reports/
!reports/.gitkeep

# Reranker shootout artifacts
reports/reranker_shootout_*.yaml
reports/reranker_shootout_*.json

# LLM trace dumps(若 dev export Langfuse traces 落 local)
# Anchored to the repo root so it doesn't shadow the frontend `/traces` route
# folder (frontend/app/(app)/traces/ — W18 F3 per ADR-0024).
/traces/
*.langfuse-export.json

# Diagnostic throwaway — W25-W42 RAG-quality investigation artifacts.
# Per-run eval payload dumps + multi-run aggregates + standalone diagnostic
# runner scripts, named `w{week}-*.{json,py}` (BUG-024/025/026/027 +
# memory project-chat-demo-rag-quality-followups). Kept on disk for reference,
# never committed (would permanently bloat history). Promote a genuinely useful
# artifact with `git add -f` (e.g. docs/eval-set-w42diag-testkb.yaml was).
backend/w[0-9]*.json
backend/w[0-9]*.py
# Background-launch uvicorn stdout+stderr capture (.log.out / .log.err / .log) —
# the bare `*.log` rule above does NOT match the `.log.out`/`.log.err` suffixes.
backend/uvicorn-*.log.out
backend/uvicorn-*.log.err
backend/uvicorn-*.log
# Background-launch frontend dev-server capture (npm run dev stdout+stderr).
frontend/*-frontend-dev.log.out
frontend/*-frontend-dev.log.err
frontend/*-frontend-dev.log

# Daily session conversation logs — local only, never push to GitHub
docs/10-development-log/

# AI assistant prompts — current snapshot already committed; future
# ad-hoc edits / new sample templates stay local. Use `git add -f` to
# intentionally update committed prompts (01-session-start.md / etc.).
docs/12-ai-assistant/

# Local screenshots cache(若 dev download Tango screenshots 暫存)
data/screenshots/
data/uploads/
data/temp/


# ----------------------------------------------------------------------------
# IDE / Editor
# ----------------------------------------------------------------------------
# VS Code(team-shared config 例外)
.vscode/*
!.vscode/settings.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/tasks.json

# JetBrains(PyCharm / WebStorm / IntelliJ)
.idea/
*.iml
*.iws

# Vim / Emacs / Sublime
*.swp
*.swo
*~
.*.swp
*.sublime-workspace

# Cursor / Zed
.cursor/
.zed/

# Claude Code(per-developer local state:settings、memory、sessions)
.claude/


# ----------------------------------------------------------------------------
# OS-specific
# ----------------------------------------------------------------------------
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
*.stackdump
[Dd]esktop.ini

# Linux
.directory
.Trash-*


# ----------------------------------------------------------------------------
# Misc
# ----------------------------------------------------------------------------
# Backup / temp
*.bak
*.tmp
*.orig
*~

# Logs
*.log
logs/

# Local sandbox / experiments
sandbox/
scratch/
playground/

# Pinned commit reference for Dify(每次 update 重新 generate)
references/DIFY_PINNED_COMMIT.txt


# ============================================================================
# End of .gitignore
# ============================================================================
