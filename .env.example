# ============================================================================
# EKP — Environment Configuration Template
# ============================================================================
#
# 使用方法:
#   cp .env.example .env
#   然後逐個填入真實 value(見下方各 section 嘅指引)
#
# ⚠️ 絕不 commit .env 入 git。.env 已喺 .gitignore 入面。
#    若不慎 commit:立即 rotate 所有 secret + force-push history rewrite。
#
# Reference:
#   - 詳細 setup 流程見 docs/setup.md §5
#   - Sensitive vs non-sensitive 分類見 docs/setup.md §5.2
#   - Beta+ 階段 secrets 應該用 Azure Key Vault,而唔係 .env
# ============================================================================


# ----------------------------------------------------------------------------
# Azure AI Search
# ----------------------------------------------------------------------------
# Where to find:
#   az search admin-key show --service-name <name> --resource-group <rg>
# Setup reference:docs/setup.md §3.2
AZURE_SEARCH_ENDPOINT=https://ekp-search-poc.search.windows.net
AZURE_SEARCH_ADMIN_KEY=
AZURE_SEARCH_DEFAULT_INDEX=ekp-kb-drive-v1


# ----------------------------------------------------------------------------
# Azure OpenAI
# ----------------------------------------------------------------------------
# Where to find endpoint + key:
#   az cognitiveservices account show --name <name> --resource-group <rg>
#   az cognitiveservices account keys list --name <name> --resource-group <rg>
# Setup reference:docs/setup.md §3.3
#
# ⚠️ Deployment names 取決於你 deploy 時用嘅 name(可能用 dash 而非 dot)
#    Decision pending OQ-Q4 in docs/decision-form.md
AZURE_OPENAI_ENDPOINT=https://ekp-openai-poc.openai.azure.com
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2025-04-01-preview

# Deployment names(對應 spec §3.2 stack table)
AZURE_OPENAI_DEPLOYMENT_EMBEDDING=text-embedding-3-large
AZURE_OPENAI_DEPLOYMENT_LLM_PRIMARY=gpt-5-5
AZURE_OPENAI_DEPLOYMENT_LLM_JUDGE=gpt-5-4-mini
AZURE_OPENAI_DEPLOYMENT_LLM_EVAL_JUDGE=gpt-5-5-pro

# Embedding config(MRL truncate from 3072 → 1024,decision pending OQ-Q19)
EMBEDDING_DIMENSION=1024


# ----------------------------------------------------------------------------
# Azure Blob Storage
# ----------------------------------------------------------------------------
# LOCAL DEV(default):用 Azurite emulator,key 係 well-known constant
# 唔需要改下面 string,docker-compose up 之後即時 work
AZURE_BLOB_CONNECTION_STRING=DefaultEndpointsProtocol=http;AccountName=devstoreaccount1;AccountKey=Eby8vdM02xNOcqFlqUwJPLlmEhGzF0ePEMoxLdF8Ok2j3pgnT88t1MUSzJGdu/XpGV1KZL3Y7gLXnUMNm5zlcA==;BlobEndpoint=http://127.0.0.1:10000/devstoreaccount1;
AZURE_BLOB_CONTAINER_SCREENSHOTS=ekp-kb-drive-screenshots

# CLOUD(POC / Beta+):取代上面 line
# Where to find:
#   az storage account show-connection-string --name <name> --resource-group <rg>
# Setup reference:docs/setup.md §3.4
# AZURE_BLOB_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net


# ----------------------------------------------------------------------------
# Cohere Rerank(W3 critical path)
# ----------------------------------------------------------------------------
# POC W3:用 direct API(decision pending OQ-Q5,default Path A)
# Beta+:切到 Azure Marketplace billing(Path B)
# Setup reference:docs/setup.md §6
COHERE_API_KEY=
# Canonical = the Azure Marketplace deployment name `Cohere-rerank-v4.0-pro`
# (W17 F4.4 naming unification — matches backend settings.py default).
COHERE_RERANK_MODEL=Cohere-rerank-v4.0-pro    # ADR-0012 W6 production lock; v3.5 W3 baseline


# ----------------------------------------------------------------------------
# W4 Reranker Mini-Shootout(W4 only,可留空到 W4)
# ----------------------------------------------------------------------------
# Reference:eval-methodology.md §7
VOYAGE_API_KEY=
ZEROENTROPY_API_KEY=


# ----------------------------------------------------------------------------
# Persistent storage(W17 F1 / ADR-0023 — KB Manager + users_repo backing)
# ----------------------------------------------------------------------------
# Empty → in-memory backend(restart-wipes;fine for local dev / CI / one-shot).
# Set → Postgres-backed KB Manager + users store. Reuses the docker-compose
# postgres service with a dedicated `ekp` database(port 5432 exposed; the
# `ekp` DB is created on a fresh volume by infrastructure/postgres-init/, or on
# an existing volume run: `docker compose exec postgres createdb -U langfuse ekp`).
# Tables auto-create via CREATE TABLE IF NOT EXISTS on connect.
# DATABASE_URL=postgresql://langfuse:langfuse_local_dev_only@localhost:5432/ekp


# ----------------------------------------------------------------------------
# Langfuse(self-host observability)
# ----------------------------------------------------------------------------
# 第一次啟動後:
#   1. docker compose up langfuse postgres
#   2. 開 http://localhost:3000 create admin account
#   3. Create project → 拎 Public Key + Secret Key 填入下面
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# Frontend Langfuse UI deep-link base URL (W16 F5.5 CO_W15_F2 — V6 Debug View
# trace_url CTA "Open in Langfuse" button consumer; mirrors LANGFUSE_HOST for
# Beta production where backend and frontend may resolve to different hosts).
NEXT_PUBLIC_LANGFUSE_URL=http://localhost:3000


# ----------------------------------------------------------------------------
# CRAG / Pipeline Tuning(L2 agentic config)
# ----------------------------------------------------------------------------
# Reference:architecture.md §3.1 + eval-methodology.md §8
CRAG_CONFIDENCE_THRESHOLD=0.70
CRAG_MAX_REFORMULATIONS=1
HYBRID_TOP_K_RETRIEVAL=50
RERANK_TOP_K=5


# ----------------------------------------------------------------------------
# Feature Flags
# ----------------------------------------------------------------------------
FEATURE_L3_ROUTING_ENABLED=false       # W5 stretch goal,default off
FEATURE_AUTH_ENABLED=false             # Beta+ enable Microsoft Entra ID

# W7 D1 F1.2.1 mock auth dev mode (per W7 plan §2 F1 a-revised 2026-05-05).
# True = bypass real MSAL JWT validation, return _DEV_USER from
# Settings.auth_mock_*. False (default + W8 D4 onwards) = real Entra ID JWT.
FEATURE_AUTH_MOCK=true                 # W7 dev sets True; W8 D4 切回 False post-IT cred delivery

# W7 D2 F2 rate limiter (per architecture.md §8.1 R5 spec).
RATE_LIMIT_ENABLED=true                # W8+ may disable for replica scaling tests
RATE_LIMIT_PER_MINUTE=50               # Per-user req/min budget
RATE_LIMIT_CONCURRENT=5                # Per-user concurrent active queries cap

# W7 D2 F1.4 frontend bearer injection (lib/auth/index.ts switching point).
# Keep in sync with backend FEATURE_AUTH_MOCK; both flip together W8 D4.
NEXT_PUBLIC_AUTH_MOCK=true

# W8 D3 F1.3 frontend msal-react config (consumed by msal_provider.ts).
# Populated W8 D2-D3 after Q11 IT delivery; W7 dev mode (NEXT_PUBLIC_AUTH_MOCK=
# true) ignores these. Values mirror backend AZURE_TENANT_ID / AZURE_CLIENT_ID
# from Key Vault. NEXT_PUBLIC_AZURE_API_SCOPE = api scope string the SPA
# requests, e.g. `api://<api-client-id>/access`.
NEXT_PUBLIC_AZURE_TENANT_ID=
NEXT_PUBLIC_AZURE_CLIENT_ID=
NEXT_PUBLIC_AZURE_API_SCOPE=


# ----------------------------------------------------------------------------
# Microsoft Entra ID(Beta+ only,POC 階段全部留空)
# ----------------------------------------------------------------------------
# Decision pending OQ-Q11 in docs/decision-form.md
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=


# ----------------------------------------------------------------------------
# Frontend(NEXT_PUBLIC_* 會暴露俾 browser)
# ----------------------------------------------------------------------------
# ⚠️ 絕不將 secret 加 NEXT_PUBLIC_ prefix(會 leak 到 client-side bundle)
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=EKP
NEXT_PUBLIC_DEFAULT_KB_ID=drive_user_manuals


# ----------------------------------------------------------------------------
# Logging / Environment
# ----------------------------------------------------------------------------
LOG_LEVEL=INFO                          # DEBUG / INFO / WARNING / ERROR
ENVIRONMENT=local                       # local / poc / beta / production


# ============================================================================
# End of .env.example
# ============================================================================
